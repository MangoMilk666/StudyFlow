## 生产环境变量（示例）
##
## 说明：
##   - 生产环境由部署平台/CI 注入环境变量，而不是在仓库里放明文密钥。
##   - 本文件仅作为字段清单和格式示例。

## ===== 必配（生产必填） =====
COMPOSE_PROJECT_NAME=studyflow
# 生产端后端在docker，db在宿主机，强制使用host.docker.internal通信
MONGO_URI=mongodb://host.docker.internal:27017/studyflow
JWT_SECRET=

CORS_ORIGINS=https://YOUR_FRONTEND_DOMAIN

## ===== 可选（按需） =====
MONGO_USERNAME=
MONGO_PASSWORD=
MONGO_AUTH_SOURCE=admin

CANVAS_BASE_URL=
CANVAS_TOKEN=

OPENAI_BASE_URL=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

CHROMA_PERSIST_DIR=/data/chroma

## ===== GitHub Actions 部署必配（Secrets） =====
## Secrets（敏感）
JWT_SECRET=
MONGO_URI=
MONGO_PASSWORD=
CANVAS_TOKEN=
OPENAI_API_KEY=
SSH_PRIVATE_KEY=

## Variables（非敏感/可见）
SERVER_HOST=
SERVER_USER=
SERVER_PORT=22
SERVER_APP_DIR=
