## 生产环境变量（示例）
##
## 说明：
##   - 生产环境建议由部署平台/CI 注入环境变量，而不是在仓库里放明文密钥。
##   - 本文件仅作为字段清单和格式示例。

PORT=8000
MOCK_MODE=false

# Docker Compose 项目名（固定后可避免重复创建 network/container/image 名称）
COMPOSE_PROJECT_NAME=studyflow

# 生产 MongoDB（建议使用 Atlas / 内网集群）
MONGO_URI=mongodb://YOUR_PROD_MONGO_HOST:27017/studyflow
MONGO_USERNAME=
MONGO_PASSWORD=
MONGO_AUTH_SOURCE=admin

# 生产 JWT 密钥（务必使用强随机）
JWT_SECRET=

# Canvas（如生产需要同步 Canvas 作业）
CANVAS_BASE_URL=
CANVAS_TOKEN=

# AI / LangChain
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# 生产建议使用持久化磁盘目录
CHROMA_PERSIST_DIR=/data/chroma

# 生产前端域名（逗号分隔）
CORS_ORIGINS=https://YOUR_FRONTEND_DOMAIN
