# --- 数据库配置 (Database) ---
# 在 Docker Compose 环境下，主机名应填写服务名 'database'
MONGO_URI=mongodb://database:27017/studyflow
# 如果是在本地非 Docker 环境运行后端，取消下面这行的注释并使用 localhost
# MONGO_URI=mongodb://127.0.0.1:27017/studyflow

# --- 后端配置 (Backend) ---
PORT=5000
NODE_ENV=development

# --- 前端配置 (Frontend - Vite) ---
# Vite 要求客户端环境变量必须以 VITE_ 开头
VITE_API_BASE_URL=http://localhost:5000/api

# --- AI 功能配置 (Optional) ---
# 如果集成了大模型分析功能，需要填入对应的 API Key
# LLM_API_KEY=your_api_key_here
# LLM_MODEL_NAME=gpt-3.5-turbo