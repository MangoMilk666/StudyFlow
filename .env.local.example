## 本地开发环境变量（示例）
##
## 使用方式：
##   1) cp .env.local.example .env.local
##   2) 按需修改 .env.local
##   3) ./dev-up.sh --mock 或 ./dev-up.sh --real
##
## 注意：
##   - .env.local 会被 gitignore 忽略，不要提交真实密钥。

# Docker Compose 项目名（固定后可避免重复创建 network/container/image 名称）
COMPOSE_PROJECT_NAME=studyflow

# 后端端口
PORT=8000

# 是否启用 MOCK_MODE（dev-up.sh 会根据 --mock/--real 覆盖该值）
MOCK_MODE=false

# MongoDB 连接串（real 模式需要）
# - 本机 Mongo：mongodb://127.0.0.1:27017/studyflow
# - Docker Compose 的 database 服务：mongodb://database:27017/studyflow
MONGO_URI=mongodb://127.0.0.1:27017/studyflow

# JWT 密钥（real 模式需要；本地可用简单值，生产请使用强随机）
JWT_SECRET=dev_secret_change_me

# Canvas LMS（可选；不配则 /api/canvas 会返回“Canvas not configured”）
CANVAS_BASE_URL=
CANVAS_TOKEN=

# AI / LangChain（可选；不配则 /api/ai/chat 返回 503）
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# 本地 RAG 向量库存储目录（相对路径时以 backend/ 为当前工作目录）
CHROMA_PERSIST_DIR=.chroma

# 前端开发站点允许跨域（逗号分隔）
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
